<SUB1.DOMAIN.COM>, <SUB2.DOMAIN.COM> {
        tls internal

        log {
                level INFO
                output file /var/log/caddy/access.log
        }

        @vault host <SUB1.DOMAIN.COM>
        handle @vault {
                reverse_proxy vaultwarden:8081 {
                        header_up X-Forwarded-For {http.request.remoteip}
                }
        }

        @file host <SUB2.DOMAIN.COM>
        handle @file {
                reverse_proxy dufs:5000 {
                        header_up X-Forwarded-For {http.request.remoteip}
                }
        }
}

localhost {
        tls internal
        respond /health 200
}
